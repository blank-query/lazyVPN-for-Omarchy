#!/bin/bash

# Fetch and cache VPN server lists.
#
# Server data is mirrored from the gluetun-servers project
# (https://github.com/qdm12/gluetun-servers, MIT License) into this repository's
# `server-data` branch by a weekly GitHub Action, and served as per-provider
# WireGuard-filtered files. We fetch from server-data — the same files the Go
# version of lazyVPN uses — rather than from gluetun directly, so a future
# upstream move doesn't break this client.

# Source common functions
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lazyvpn-common" || exit 1
# shellcheck source=./lazyvpn-common

CONFIG_DIR="$HOME/.config/lazyvpn"
CACHE_DIR="$CONFIG_DIR/cache"
PROVIDERS_DIR="$CONFIG_DIR/providers"

# Per-provider server lists on the server-data branch. Each provider is a
# separate file: <base>/<gluetun_name>.json, shape { "version", "servers": [...] }.
SERVERS_BASE_URL="https://raw.githubusercontent.com/blank-query/lazyVPN-for-Omarchy/server-data"

# Cache expiry (1 week in seconds) — server-data refreshes weekly, so a shorter
# window would just re-pull identical data.
CACHE_EXPIRY=604800

# Ensure directories exist
mkdir -p "$CACHE_DIR"

# Check for jq
if ! command -v jq &>/dev/null; then
  error "jq is required but not installed. Install with: sudo pacman -S jq"
fi

# Fetch and cache the WireGuard server list for a single provider.
# Downloads <gluetun_name>.json from the server-data branch, filters to valid
# WireGuard servers, and writes the sorted array to ${provider}_servers.json.
# Pass --force as $2 to ignore the cache.
fetch_provider_servers() {
  local provider="$1"
  local force="$2"
  local provider_file="$CACHE_DIR/${provider}_servers.json"

  local gluetun_name="${GLUETUN_PROVIDER_MAP[$provider]}"
  if [[ -z "$gluetun_name" ]]; then
    error "Unknown provider: $provider"
  fi

  # Reuse a fresh cache unless forced
  if [[ "$force" != "--force" ]] && [[ -f "$provider_file" ]]; then
    local file_age=$(($(date +%s) - $(stat -c %Y "$provider_file")))
    if [[ $file_age -lt $CACHE_EXPIRY ]]; then
      local hours_old=$((file_age / 3600))
      echo "Using cached ${PROVIDER_DISPLAY[$provider]} server list (${hours_old}h old)"
      return 0
    fi
  fi

  echo "Fetching ${PROVIDER_DISPLAY[$provider]} servers from server-data..."
  local url="$SERVERS_BASE_URL/${gluetun_name}.json"
  local raw="${provider_file}.raw.tmp"

  if ! curl -s --connect-timeout 10 --max-time 60 -o "$raw" "$url"; then
    secure_delete "$raw" 2>/dev/null
    if [[ -f "$provider_file" ]]; then
      warn "Failed to fetch ${PROVIDER_DISPLAY[$provider]} servers, using cached data"
      return 0
    fi
    error "Failed to fetch servers for $provider and no cache available"
  fi

  # Validate JSON
  if ! jq empty "$raw" 2>/dev/null; then
    secure_delete "$raw"
    if [[ -f "$provider_file" ]]; then
      warn "Downloaded data is invalid JSON, using cached data"
      return 0
    fi
    error "Downloaded data is invalid JSON and no cache available"
  fi

  # Filter: WireGuard only, must have a public key and IPs; sorted.
  # The server-data files are already WireGuard-filtered, so this mainly
  # re-validates and sorts into the array shape the other scripts expect.
  local out="${provider_file}.tmp"
  if ! jq '
    .servers
    | map(select(
        .vpn == "wireguard"
        and (.wgpubkey != null and .wgpubkey != "")
        and (.ips != null and (.ips | length) > 0)
      ))
    | sort_by(.country, .city, .server_name)
  ' "$raw" > "$out" 2>/dev/null; then
    secure_delete "$raw"
    secure_delete "$out"
    error "Failed to filter servers for $provider"
  fi
  secure_delete "$raw"

  # Check if we got any servers
  local server_count
  server_count=$(jq 'length' "$out")

  if [[ "$server_count" -eq 0 ]]; then
    secure_delete "$out"
    error "No WireGuard servers found for ${PROVIDER_DISPLAY[$provider]}"
  fi

  mv "$out" "$provider_file"

  # Generate stats
  local countries
  countries=$(jq '[.[].country] | unique | length' "$provider_file")

  echo ""
  echo "Server list for ${PROVIDER_DISPLAY[$provider]}:"
  echo "  Total servers: $server_count"
  echo "  Countries: $countries"
  echo "  Cache file: $provider_file"
  echo ""

  # Show breakdown by feature
  local p2p_count tor_count sc_count stream_count free_count
  p2p_count=$(jq '[.[] | select(.port_forward == true)] | length' "$provider_file")
  tor_count=$(jq '[.[] | select(.tor == true)] | length' "$provider_file")
  sc_count=$(jq '[.[] | select(.secure_core == true)] | length' "$provider_file")
  stream_count=$(jq '[.[] | select(.stream == true)] | length' "$provider_file")
  free_count=$(jq '[.[] | select(.free == true)] | length' "$provider_file")

  echo "Features:"
  [[ $p2p_count -gt 0 ]] && echo "  🔄 P2P/Port Forward: $p2p_count"
  [[ $tor_count -gt 0 ]] && echo "  🧅 Tor: $tor_count"
  [[ $sc_count -gt 0 ]] && echo "  🔒 Secure Core: $sc_count"
  [[ $stream_count -gt 0 ]] && echo "  📺 Streaming: $stream_count"
  [[ $free_count -gt 0 ]] && echo "  🤡 Free: $free_count"

  return 0
}

# List configured providers
list_providers() {
  echo "Configured providers:"
  local found=false

  for provider_file in "$PROVIDERS_DIR"/*.conf; do
    if [[ -f "$provider_file" ]]; then
      found=true
      local provider
      provider=$(basename "$provider_file" .conf)
      local display_name="${PROVIDER_DISPLAY[$provider]:-$provider}"

      # Check cache status
      local cache_file="$CACHE_DIR/${provider}_servers.json"
      if [[ -f "$cache_file" ]]; then
        local server_count
        server_count=$(jq 'length' "$cache_file" 2>/dev/null || echo "0")
        local cache_age=$(($(date +%s) - $(stat -c %Y "$cache_file")))
        local hours_old=$((cache_age / 3600))

        if [[ $cache_age -gt $CACHE_EXPIRY ]]; then
          echo "  • $display_name: $server_count servers (cache expired, ${hours_old}h old)"
        else
          echo "  • $display_name: $server_count servers (${hours_old}h old)"
        fi
      else
        echo "  • $display_name: (no cache - run fetch)"
      fi
    fi
  done

  if [[ "$found" == "false" ]]; then
    echo "  No providers configured."
    echo ""
    echo "Run 'lazyvpn-provider-setup' to add a provider."
  fi
}

# Main
case "$1" in
  --list|-l)
    list_providers
    ;;

  --force|-f)
    # Refresh all configured providers
    for provider_file in "$PROVIDERS_DIR"/*.conf; do
      if [[ -f "$provider_file" ]]; then
        provider=$(basename "$provider_file" .conf)
        fetch_provider_servers "$provider" --force
      fi
    done
    ;;

  --help|-h)
    echo "LazyVPN Server Fetcher"
    echo ""
    echo "Downloads and caches WireGuard server lists from the server-data branch"
    echo "(mirrored weekly from the gluetun-servers project, MIT License)."
    echo ""
    echo "Usage:"
    echo "  lazyvpn-fetch-servers              # Fetch for all configured providers"
    echo "  lazyvpn-fetch-servers PROVIDER     # Fetch for specific provider"
    echo "  lazyvpn-fetch-servers --force      # Force refresh (ignore cache)"
    echo "  lazyvpn-fetch-servers --list       # List providers and cache status"
    echo ""
    echo "Providers: protonvpn, mullvad, ivpn, nordvpn, surfshark, windscribe"
    ;;

  "")
    # No argument - fetch for all configured providers
    found=false
    for provider_file in "$PROVIDERS_DIR"/*.conf; do
      if [[ -f "$provider_file" ]]; then
        found=true
        provider=$(basename "$provider_file" .conf)
        fetch_provider_servers "$provider"
      fi
    done

    if [[ "$found" == "false" ]]; then
      echo "No providers configured."
      echo ""
      echo "Run 'lazyvpn-provider-setup' to add a provider."
    fi
    ;;

  *)
    # Specific provider
    provider="$1"

    # Validate provider name
    if [[ -z "${PROVIDER_DISPLAY[$provider]}" ]]; then
      error "Unknown provider: $provider"
    fi

    # Check if provider is configured
    if [[ ! -f "$PROVIDERS_DIR/${provider}.conf" ]]; then
      warn "Provider $provider is not configured. Fetching anyway..."
    fi

    fetch_provider_servers "$provider"
    ;;
esac
